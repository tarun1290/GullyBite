# Main API base URL — EC2 backend (webhooks/crons + general /api/* traffic).
VITE_API_BASE_URL=https://gullybite.duckdns.org

# Auth API base URL — Vercel deployment. All /auth/* calls route here because
# ec2-server.js intentionally does NOT handle auth routes.
# Set this to your Vercel deployment URL (e.g. https://gullybite.vercel.app).
# Must ALSO be set in the Vercel dashboard under the frontend project's
# environment variables for the production build.
VITE_AUTH_API_BASE_URL=https://gullybite.vercel.app
