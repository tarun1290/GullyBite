{
  "version": "6.2",
  "routing_model": {
    "SAVED_ADDRESSES": ["NEW_ADDRESS"],
    "NEW_ADDRESS": []
  },
  "screens": [
    {
      "id": "SAVED_ADDRESSES",
      "title": "Your Addresses",
      "terminal": true,
      "success": true,
      "data": {
        "addresses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "metadata": { "type": "string" }
            }
          },
          "__example__": [
            {
              "id": "addr_1",
              "title": "Home",
              "description": "Tarun • Flat 4B, Green Valley, Madhapur",
              "metadata": "Hyderabad, 500081 • 9876543210"
            }
          ]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Select Delivery Address"
          },
          {
            "type": "RadioButtonsGroup",
            "name": "selected_address_id",
            "label": "Your saved addresses",
            "required": false,
            "data-source": "${data.addresses}"
          },
          {
            "type": "EmbeddedLink",
            "text": "➕ Add new address",
            "on-click-action": {
              "name": "navigate",
              "next": {
                "type": "screen",
                "name": "NEW_ADDRESS"
              },
              "payload": {}
            }
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "action": "select_address",
                "address_id": "${form.selected_address_id}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "NEW_ADDRESS",
      "title": "Add Delivery Address",
      "terminal": true,
      "success": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Add Delivery Address"
          },
          {
            "type": "TextInput",
            "name": "recipient_name",
            "label": "Recipient Name",
            "required": true,
            "helper-text": "Name of the person receiving the order"
          },
          {
            "type": "TextInput",
            "name": "delivery_phone",
            "label": "Delivery Phone",
            "required": true,
            "input-type": "phone",
            "helper-text": "We'll call this number at delivery"
          },
          {
            "type": "TextInput",
            "name": "house_number",
            "label": "Flat / House No.",
            "required": true
          },
          {
            "type": "TextInput",
            "name": "building_street",
            "label": "Building / Street",
            "required": true
          },
          {
            "type": "TextInput",
            "name": "area_locality",
            "label": "Area / Locality",
            "required": true
          },
          {
            "type": "TextInput",
            "name": "landmark",
            "label": "Landmark",
            "required": false,
            "helper-text": "e.g. Near Apollo Hospital"
          },
          {
            "type": "TextInput",
            "name": "city",
            "label": "City",
            "required": true
          },
          {
            "type": "TextInput",
            "name": "pincode",
            "label": "Pincode",
            "required": true,
            "input-type": "number"
          },
          {
            "type": "TextInput",
            "name": "nickname",
            "label": "Address Nickname",
            "required": false,
            "helper-text": "e.g. Office, Mom's house (optional)"
          },
          {
            "type": "Dropdown",
            "name": "label",
            "label": "Save as",
            "required": true,
            "data-source": [
              { "id": "Home", "title": "Home" },
              { "id": "Work", "title": "Work" },
              { "id": "Other", "title": "Other" }
            ]
          },
          {
            "type": "Footer",
            "label": "Save Address",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "action": "add_address",
                "recipient_name": "${form.recipient_name}",
                "delivery_phone": "${form.delivery_phone}",
                "house_number": "${form.house_number}",
                "building_street": "${form.building_street}",
                "area_locality": "${form.area_locality}",
                "landmark": "${form.landmark}",
                "city": "${form.city}",
                "pincode": "${form.pincode}",
                "nickname": "${form.nickname}",
                "label": "${form.label}"
              }
            }
          }
        ]
      }
    }
  ]
}
