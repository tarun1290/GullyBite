{
  "regions": ["bom1"],
  "functions": {
    "api/index.js": {
      "includeFiles": "{frontend,backend}/**",
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/catalog-sync",
      "schedule": "*/30 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
