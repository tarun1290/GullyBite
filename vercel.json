{
  "buildCommand": "cd frontend && npm install --include=dev && npm run build",
  "installCommand": "cd frontend && npm install --include=dev",
  "outputDirectory": "frontend/dist",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/auth/:path*", "destination": "https://gullybite.duckdns.org/auth/:path*" },
    { "source": "/api/:path*", "destination": "https://gullybite.duckdns.org/api/:path*" },
    { "source": "/((?!api|auth).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=60, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}