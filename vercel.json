{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/auth/(.*)",           "dest": "backend/server.js" },
    { "src": "/api/(.*)",            "dest": "backend/server.js" },
    { "src": "/webhooks/(.*)",       "dest": "backend/server.js" },
    { "src": "/payment-success",     "dest": "backend/server.js" },
    { "src": "/health",              "dest": "backend/server.js" },
    { "src": "/(.*\\.(js|css|png|jpg|ico|svg))", "dest": "frontend/$1" },
    { "src": "/(.*)",                "dest": "frontend/index.html" }
  ]
}