# ================================================================
# GullyBite — Environment Variables
# HOW TO USE: Copy this file → rename to .env → fill all values
# Command:  cp .env.example .env
# ================================================================

# ── SERVER ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
ADMIN_KEY=your-admin-key-here

# Your public URL. During development use your ngrok URL.
# Get ngrok: https://ngrok.com (free) → run: ngrok http 3000
# Production: use your real domain like https://api.gullybite.com
BASE_URL=https://your-domain.com

# Secret for signing login tokens. Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# ── DATABASE (MongoDB) ────────────────────────────────────────
# MongoDB connection string
# Local:   mongodb://localhost:27017/gullybite
# Atlas:   mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/gullybite
MONGODB_URI=mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/gullybite

# ── GOOGLE OAUTH (Restaurant Login) ────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Create a "Web application" client type.
# Add your domain to "Authorized JavaScript origins" (e.g. https://gully-bite.vercel.app)
# No redirect URI needed — uses popup/postmessage mode.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── GOOGLE MAPS (required — geocoding + branch address autocomplete) ──
# Create at: console.cloud.google.com → APIs & Services → Credentials → Create API Key
# Enable these APIs in Google Cloud Console:
#   1. Geocoding API — customer location reverse geocoding (lat/lng → address)
#   2. Places API (New) — branch address autocomplete in the dashboard
# No Maps JavaScript API is needed — all requests go through the backend.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── META / FACEBOOK (WhatsApp Business Connection) ─────────────
# Used for WhatsApp Embedded Signup, NOT for login.
# developers.facebook.com → Your App → Settings → Basic
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# ┌──────────────────────────────────────────────────────────────┐
# │  META OAUTH REDIRECT URI                                     │
# │  Where Meta redirects users after they approve your app.     │
# │                                                              │
# │  Set this EXACT URL in Meta Developer Console:               │
# │  Meta App → Facebook Login → Settings →                     │
# │    Valid OAuth Redirect URIs                                  │
# │                                                              │
# │  Also add in:                                                │
# │  Meta App → Settings → Basic → App Domains                  │
# └──────────────────────────────────────────────────────────────┘
META_OAUTH_REDIRECT_URI={BASE_URL}/auth/callback

# ── META SYSTEM USER TOKEN (never-expiring) ──────────────────
# ONE token for ALL Meta API calls: WhatsApp messaging + catalog + business management.
# Per Meta docs, a single System User token works for everything based on its scopes.
#
# How to generate:
#   1. Business Manager → Settings → System Users
#   2. Select your system user (or create one with Admin role)
#   3. Click "Generate Token" → select your app
#   4. Select ALL of these permissions:
#      - whatsapp_business_messaging
#      - whatsapp_business_management
#      - catalog_management
#      - business_management
#   5. Set expiration to "Never" (for production)
#   6. Click "Generate Token" and copy it here
#
# Verify at startup: check server logs for "[MetaConfig] ✅ All required scopes present"
# Debug anytime: GET /api/admin/meta/token-debug (requires ADMIN_KEY)
META_SYSTEM_USER_TOKEN=your-system-user-token

# Optional: dedicated catalog token. If not set, META_SYSTEM_USER_TOKEN is used.
# You typically do NOT need this — the system user token handles everything.
# META_CATALOG_TOKEN=

META_BUSINESS_ID=your-business-portfolio-id

# ── WHATSAPP ────────────────────────────────────────────────────
# API version - keep as v25.0 (current stable)
WA_API_VERSION=v25.0

# ┌──────────────────────────────────────────────────────────────┐
# │  WHATSAPP WEBHOOK CONFIGURATION                              │
# │                                                              │
# │  In Meta Developer Console:                                  │
# │  Meta App → WhatsApp → Configuration → Webhook               │
# │                                                              │
# │  Callback URL:    {BASE_URL}/webhooks/whatsapp               │
# │  Verify Token:    (paste the value you set below)            │
# │                                                              │
# │  Subscribed Fields (tick all these):                         │
# │    ✅ messages                                                │
# │    ✅ message_template_status_update                          │
# │    ✅ messaging_handovers                                     │
# │    ✅ message_template_quality_update                         │
# └──────────────────────────────────────────────────────────────┘

# A string YOU choose. Used to verify Meta's webhook setup call.
# Any random text works: "GullyBite-secret-2024" etc.
# Must match exactly what you enter in Meta Developer Console webhook settings
WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# Same as META_APP_SECRET - used to verify webhook request signatures
WEBHOOK_APP_SECRET=your-meta-app-secret

# ── RAZORPAY ────────────────────────────────────────────────────
# Get these from: razorpay.com → Settings → API Keys
# Use rzp_test_ keys for testing, rzp_live_ for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ┌──────────────────────────────────────────────────────────────┐
# │  RAZORPAY WEBHOOK                                            │
# │                                                              │
# │  In Razorpay Dashboard:                                      │
# │  Settings → Webhooks → + Add New Webhook                    │
# │                                                              │
# │  Webhook URL:     {BASE_URL}/webhooks/razorpay               │
# │  Secret:          (paste the value you set below)            │
# │                                                              │
# │  Events to subscribe:                                        │
# │    ✅ order.paid                                              │
# │    ✅ payment.captured                                        │
# │    ✅ payment_link.paid                                       │
# │    ✅ payout.processed                                        │
# │    ✅ payout.failed                                           │
# │    ✅ refund.processed                                        │
# └──────────────────────────────────────────────────────────────┘
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# How long before WhatsApp Pay / payment links expire (minutes)
PAYMENT_LINK_EXPIRY_MINS=15

# ── WHATSAPP PAY (Razorpay) ──────────────────────────────────────
# Configuration name from Meta Business Manager:
#   WhatsApp Manager → Payment Settings → Add payment configuration → Name
# Must match exactly — links Meta's native payment UI to your Razorpay account
RAZORPAY_WA_CONFIG_NAME=YourAppName

# Razorpay X virtual account number for outgoing payouts to restaurants
# Found at: razorpay.com → Razorpay X → Account Settings → Account Number
RAZORPAY_ACCOUNT_NUMBER=

# ── PLATFORM FEES ───────────────────────────────────────────────
# Your commission percentage from restaurant earnings
PLATFORM_FEE_PERCENT=0

# Default delivery fee charged to customers (in rupees)
# Used as fallback when 3PL quote fails
DEFAULT_DELIVERY_FEE=40

# ── 3PL DELIVERY PROVIDER ─────────────────────────────────────
# Which provider to use: 'porter' | 'dunzo' | 'shadowfax' | 'borzo'
DEFAULT_DELIVERY_PROVIDER=porter

# Porter API (apply at porter.in/business)
PORTER_API_KEY=your-porter-api-key
PORTER_BASE_URL=https://pfe-apigw-uat.porter.in
# Production: https://pfe-apigw.porter.in

# ┌──────────────────────────────────────────────────────────────┐
# │  PORTER WEBHOOK (3PL delivery status updates)                │
# │                                                              │
# │  In Porter Dashboard:                                        │
# │  Settings → Webhooks / API Config                            │
# │                                                              │
# │  Webhook URL:     {BASE_URL}/webhooks/delivery               │
# │                                                              │
# │  Porter will POST rider status updates (assigned, picked_up, │
# │  delivered, cancelled) to this URL.                          │
# └──────────────────────────────────────────────────────────────┘

# Platform markup on delivery fee (% on top of 3PL cost, 0 = pass-through)
DELIVERY_PLATFORM_MARKUP_PCT=0

# Dunzo API (future)
# DUNZO_API_KEY=
# DUNZO_BASE_URL=https://apis.staging.dunzo.in

# Shadowfax API (future)
# SHADOWFAX_API_KEY=
# SHADOWFAX_BASE_URL=

# ── WHATSAPP CATALOG WEBHOOK ──────────────────────────────────
# ┌──────────────────────────────────────────────────────────────┐
# │  CATALOG WEBHOOK                                             │
# │                                                              │
# │  This is automatically handled by the main WhatsApp webhook. │
# │  No separate URL needed — catalog events arrive at:          │
# │  {BASE_URL}/webhooks/catalog                                 │
# │                                                              │
# │  Ensure "catalog" is subscribed in WhatsApp webhook fields.  │
# └──────────────────────────────────────────────────────────────┘

# ── WHATSAPP DIRECTORY (separate WABA for discovery) ───────────
# A second WhatsApp Business number used for restaurant discovery.
# Customers message this number to search/browse restaurants.
#
# ┌──────────────────────────────────────────────────────────────┐
# │  DIRECTORY WABA WEBHOOK                                      │
# │                                                              │
# │  In Meta Developer Console (for your DIRECTORY app/WABA):    │
# │  Meta App → WhatsApp → Configuration → Webhook               │
# │                                                              │
# │  Callback URL:    {BASE_URL}/webhooks/directory              │
# │  Verify Token:    (paste the value you set below)            │
# │                                                              │
# │  Subscribed Fields:                                          │
# │    ✅ messages                                                │
# └──────────────────────────────────────────────────────────────┘
DIRECTORY_WA_PHONE_NUMBER_ID=
DIRECTORY_WA_ACCESS_TOKEN=
DIRECTORY_WA_VERIFY_TOKEN=your-directory-verify-token

# ── WHATSAPP CHECKOUT (encrypted order flow) ───────────────────
# WhatsApp Checkout sends encrypted order data using RSA+AES-GCM.
#
# ┌──────────────────────────────────────────────────────────────┐
# │  CHECKOUT WEBHOOK                                            │
# │                                                              │
# │  In Meta Developer Console:                                  │
# │  Meta App → WhatsApp → Configuration → Checkout Settings     │
# │                                                              │
# │  Callback URL:    {BASE_URL}/webhooks/checkout               │
# │  Verify Token:    (paste the value you set below)            │
# │                                                              │
# │  Public Key:      Upload the RSA public key generated via    │
# │                   POST /api/admin/checkout/generate-keys     │
# │                                                              │
# │  Webhook Secret:  Set a secret below, enter the same in Meta │
# └──────────────────────────────────────────────────────────────┘
#
# Generate RSA keys: POST /api/admin/checkout/generate-keys
# Then set privateKeyB64 here and upload publicKey to Meta
WA_CHECKOUT_PRIVATE_KEY_B64=
WA_CHECKOUT_VERIFY_TOKEN=your-checkout-verify-token
WA_CHECKOUT_WEBHOOK_SECRET=your-checkout-webhook-secret


# ── FEATURE FLAGS ─────────────────────────────────────────────
# POS integrations (PetPooja, UrbanPiper, DotPe) — set to true to activate
ENABLE_POS_INTEGRATIONS=false

# ── AWS S3 + CloudFront (disabled — add credentials to enable image pipeline) ──
# Product images stored in S3, served via CloudFront CDN.
# Auto-enables when all 4 vars are set. See docs/aws-image-setup.md.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=gullybite-images
# AWS_CLOUDFRONT_DOMAIN=

# ── POS INTEGRATIONS (disabled — set ENABLE_POS_INTEGRATIONS=true to activate) ──
# Per-restaurant credentials are entered in the dashboard.
# Platform-level keys only needed for PetPooja:
# PETPOOJA_APP_KEY=
# PETPOOJA_API_KEY=

# ================================================================
# QUICK REFERENCE — ALL URLs TO SET IN EXTERNAL DASHBOARDS
# ================================================================
#
# Replace {BASE_URL} with your actual domain (e.g. https://api.gullybite.com)
#
# ┌─────────────────────┬────────────────────────────────────────┐
# │ WHERE TO SET        │ URL                                    │
# ├─────────────────────┼────────────────────────────────────────┤
# │ Meta OAuth Redirect │ {BASE_URL}/auth/callback               │
# │                     │ (Facebook Login → Valid OAuth URIs)     │
# ├─────────────────────┼────────────────────────────────────────┤
# │ WhatsApp Webhook    │ {BASE_URL}/webhooks/whatsapp           │
# │                     │ (Meta App → WhatsApp → Configuration)  │
# ├─────────────────────┼────────────────────────────────────────┤
# │ Razorpay Webhook    │ {BASE_URL}/webhooks/razorpay           │
# │                     │ (Razorpay → Settings → Webhooks)       │
# ├─────────────────────┼────────────────────────────────────────┤
# │ Porter/3PL Webhook  │ {BASE_URL}/webhooks/delivery           │
# │                     │ (Porter Dashboard → Settings)           │
# ├─────────────────────┼────────────────────────────────────────┤
# │ Directory Webhook   │ {BASE_URL}/webhooks/directory          │
# │                     │ (Meta App #2 → WhatsApp → Config)      │
# ├─────────────────────┼────────────────────────────────────────┤
# │ Checkout Webhook    │ {BASE_URL}/webhooks/checkout           │
# │                     │ (Meta App → WhatsApp → Checkout)        │
# ├─────────────────────┼────────────────────────────────────────┤
# │ Catalog Feed URL    │ {BASE_URL}/feed/{feedToken}            │
# │                     │ (Meta Commerce Manager → Data Sources)  │
# ├─────────────────────┼────────────────────────────────────────┤
# │ Payment Success     │ {BASE_URL}/payment-success             │
# │                     │ (Razorpay Payment Link → Callback URL)  │
# └─────────────────────┴────────────────────────────────────────┘
