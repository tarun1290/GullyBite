# ================================================================
# GullyBite — Environment Variables
# HOW TO USE: Copy this file → rename to .env → fill all values
# Command:  cp .env.example .env
# ================================================================

# ── SERVER ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# ADMIN_KEY has been removed — admin auth is JWT-based (email + password).
# See the admin_users collection + /api/admin/auth/setup for first-run.
MONGODB_DB=gullybite

# ── CORS ALLOWLIST (comma-separated origins) ─────────────────
# Required in production. localhost entries are added automatically in
# development. No wildcard fallback — an unset value rejects all cross-origin
# requests. Example: CORS_ALLOWED_ORIGINS=https://gully-bite.vercel.app,https://admin.gullybite.com
CORS_ALLOWED_ORIGINS=

# ── EC2 WEBHOOK BACKEND (set on Vercel to offload webhooks to EC2) ──
# USE_EC2_WEBHOOKS=true
# EC2_BACKEND_URL=https://api.gullybite.com

# Your public URL. During development use your ngrok URL.
# Get ngrok: https://ngrok.com (free) → run: ngrok http 3000
# Production: use your real domain like https://api.gullybite.com
BASE_URL=https://your-domain.com

# Secret for signing login tokens. Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# Secret for signing staff POS JWTs (tablet login via 4-digit PIN,
# 30-day expiry). If unset the middleware falls back to JWT_SECRET with
# a `staff:` prefix — fine for dev, but set an independent secret in
# production so staff tokens can never substitute for customer tokens.
STAFF_JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# ── DATABASE (MongoDB) ────────────────────────────────────────
# MongoDB connection string
# Local:   mongodb://localhost:27017/gullybite
# Atlas:   mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/gullybite
MONGODB_URI=mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/gullybite

# ── GOOGLE OAUTH (Restaurant Login) ────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Create a "Web application" client type.
# Add your domain to "Authorized JavaScript origins" (e.g. https://gully-bite.vercel.app)
# No redirect URI needed — uses popup/postmessage mode.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── ADDRESS FLOW (WhatsApp Flow endpoint) ─────────────────────
# Public HTTPS URL where Meta delivers address-Flow runtime callbacks
# (INIT / data_exchange / BACK). Must match the /flow/address route
# registered in server.js. Default is gullybite.duckdns.org; override
# per-environment.
ADDRESS_FLOW_ENDPOINT_URI=https://gullybite.duckdns.org/flow/address

# ── GOOGLE MAPS (required — geocoding + address autocomplete) ──
# Create at: console.cloud.google.com → APIs & Services → Credentials → Create API Key
# Enable these APIs in Google Cloud Console:
#   1. Geocoding API — customer location reverse geocoding (lat/lng → address)
#   2. Places API (New) — branch address autocomplete in the dashboard AND
#      the WhatsApp address Flow endpoint at /flow/address (locality search
#      dropdown + place_id → lat/lng resolution on submit).
# No Maps JavaScript API is needed — all requests go through the backend.
# Note: GOOGLE_PLACES_API_KEY is intentionally NOT a separate var — the
# same key powers Places Autocomplete, Place Details, Geocoding, and any
# future Maps calls. If you need to rotate Places independently, split here.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── META / FACEBOOK (WhatsApp Business Connection) ─────────────
# Used for WhatsApp Embedded Signup, NOT for login.
# developers.facebook.com → Your App → Settings → Basic
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# ┌──────────────────────────────────────────────────────────────┐
# │  META OAUTH REDIRECT URI                                     │
# │  Where Meta redirects users after they approve your app.     │
# │                                                              │
# │  Set this EXACT URL in Meta Developer Console:               │
# │  Meta App → Facebook Login → Settings →                     │
# │    Valid OAuth Redirect URIs                                  │
# │                                                              │
# │  Also add in:                                                │
# │  Meta App → Settings → Basic → App Domains                  │
# └──────────────────────────────────────────────────────────────┘
META_OAUTH_REDIRECT_URI={BASE_URL}/auth/callback

# ── META SYSTEM USER TOKEN (never-expiring) ──────────────────
# ONE token for ALL Meta API calls: WhatsApp messaging + catalog + business management.
# Per Meta docs, a single System User token works for everything based on its scopes.
#
# How to generate:
#   1. Business Manager → Settings → System Users
#   2. Select your system user (or create one with Admin role)
#   3. Click "Generate Token" → select your app
#   4. Select ALL of these permissions:
#      - whatsapp_business_messaging
#      - whatsapp_business_management
#      - catalog_management
#      - business_management
#   5. Set expiration to "Never" (for production)
#   6. Click "Generate Token" and copy it here
#
# Verify at startup: check server logs for "[MetaConfig] ✅ All required scopes present"
# Debug anytime: GET /api/admin/meta/token-debug (requires admin JWT)
META_SYSTEM_USER_TOKEN=your-system-user-token

# Optional: dedicated catalog token. If not set, META_SYSTEM_USER_TOKEN is used.
# META_CATALOG_TOKEN=
# NOTE: WA_CATALOG_TOKEN is deprecated and IGNORED. Only META_SYSTEM_USER_TOKEN is used.

META_BUSINESS_ID=your-business-portfolio-id

# ── WHATSAPP ────────────────────────────────────────────────────
# API version - keep as v25.0 (current stable)
WA_API_VERSION=v25.0

# ┌──────────────────────────────────────────────────────────────┐
# │  WHATSAPP WEBHOOK CONFIGURATION                              │
# │                                                              │
# │  In Meta Developer Console:                                  │
# │  Meta App → WhatsApp → Configuration → Webhook               │
# │                                                              │
# │  Callback URL:    {BASE_URL}/webhooks/whatsapp               │
# │  Verify Token:    (paste the value you set below)            │
# │                                                              │
# │  Subscribed Fields (tick all these):                         │
# │    ✅ messages                                                │
# │    ✅ message_template_status_update                          │
# │    ✅ messaging_handovers                                     │
# │    ✅ message_template_quality_update                         │
# └──────────────────────────────────────────────────────────────┘

# A string YOU choose. Used to verify Meta's webhook setup call.
# Any random text works: "GullyBite-secret-2024" etc.
# Must match exactly what you enter in Meta Developer Console webhook settings
WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# Same as META_APP_SECRET - used to verify webhook request signatures
WEBHOOK_APP_SECRET=your-meta-app-secret

# ── RAZORPAY ────────────────────────────────────────────────────
# Get these from: razorpay.com → Settings → API Keys
# Use rzp_test_ keys for testing, rzp_live_ for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ┌──────────────────────────────────────────────────────────────┐
# │  RAZORPAY WEBHOOK                                            │
# │                                                              │
# │  In Razorpay Dashboard:                                      │
# │  Settings → Webhooks → + Add New Webhook                    │
# │                                                              │
# │  Webhook URL:     {BASE_URL}/webhooks/razorpay               │
# │  Secret:          (paste the value you set below)            │
# │                                                              │
# │  Events to subscribe:                                        │
# │    ✅ order.paid                                              │
# │    ✅ payment.captured                                        │
# │    ✅ payment_link.paid                                       │
# │    ✅ payout.processed                                        │
# │    ✅ payout.failed                                           │
# │    ✅ refund.processed                                        │
# └──────────────────────────────────────────────────────────────┘
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# How long before WhatsApp Pay / payment links expire (minutes)
PAYMENT_LINK_EXPIRY_MINS=15

# ── WHATSAPP PAY (Razorpay) ──────────────────────────────────────
# Configuration name from Meta Business Manager:
#   WhatsApp Manager → Payment Settings → Add payment configuration → Name
# Must match exactly — links Meta's native payment UI to your Razorpay account
RAZORPAY_WA_CONFIG_NAME=YourAppName

# Razorpay X virtual account number for outgoing payouts to restaurants
# Found at: razorpay.com → Razorpay X → Account Settings → Account Number
RAZORPAY_ACCOUNT_NUMBER=

# ── MANUAL PAYOUTS (non-Razorpay fallback) ──────────────────────
# When true, settlements routed to 'fallback_provider' (because Razorpay
# failed or is not configured) are marked status='pending_manual_payout'
# for ops to transfer out-of-band, then confirmed via POST /admin/settlements/confirm.
# When false, fallback_provider throws — use this in environments where
# only Razorpay should ever move money.
MANUAL_PAYOUTS_ENABLED=true

# ── CAMPAIGN SEND CAP ───────────────────────────────────────────
# Platform-wide fallback for the per-restaurant daily campaign cap
# (CRIT-2B-10). A restaurant can override this via
# restaurants.campaign_daily_cap (admin PATCH /restaurants/:id/campaign-cap).
# Set to 0 to disable sends entirely by default; bump higher for agencies.
CAMPAIGN_DEFAULT_DAILY_CAP=3

# ── BSUID (WhatsApp Username) rollout ───────────────────────────
# Meta begins sending w-prefixed BSUIDs as sender IDs from June 2026.
# No config change needed — platform auto-detects and stores BSUIDs
# alongside phone numbers (customers.bsuid + bsuid_seen_at).
# Monitor logs for "[BSUID]" prefix to track rollout progress.

# ── PLATFORM FEES ───────────────────────────────────────────────
# Default delivery fee charged to customers (in rupees, fallback when 3PL quote fails)
DEFAULT_DELIVERY_FEE=40

# ── 3PL DELIVERY PROVIDER ─────────────────────────────────────
# Set to "mock" for testing (simulates quotes + dispatch), or real provider when onboarded
# Supported: 'mock' | 'porter' | 'dunzo' | 'shadowfax' | 'borzo'
DEFAULT_DELIVERY_PROVIDER=mock

# Porter API (apply at porter.in/business)
PORTER_API_KEY=your-porter-api-key
PORTER_BASE_URL=https://pfe-apigw-uat.porter.in
# Production: https://pfe-apigw.porter.in

# Prorouting API (3PL dispatch — direct integration, bypasses the
# DEFAULT_DELIVERY_PROVIDER abstraction). Quote fetched at checkout time
# (/estimate) then pinned via `select_criteria.mode=estimated_price` at
# /createasync. Webhook lands at {BASE_URL}/webhook/prorouting and
# authenticates via `x-pro-api-key` matching PROROUTING_API_KEY.
PROROUTING_API_KEY=
PROROUTING_BASE_URL=https://preprod.logistics-buyer.prorouting.in
# Optional override — defaults to https://gullybite.duckdns.org/webhook/prorouting
PROROUTING_CALLBACK_URL=https://gullybite.duckdns.org/webhook/prorouting
# GullyBite ops number to notify on RTO events (optional — phone in
# international format, e.g. 919900000000). Alongside branch.manager_phone.
# ADMIN_NOTIFY_NUMBER=

# ┌──────────────────────────────────────────────────────────────┐
# │  PORTER WEBHOOK (3PL delivery status updates)                │
# │                                                              │
# │  In Porter Dashboard:                                        │
# │  Settings → Webhooks / API Config                            │
# │                                                              │
# │  Webhook URL:     {BASE_URL}/webhooks/delivery               │
# │                                                              │
# │  Porter will POST rider status updates (assigned, picked_up, │
# │  delivered, cancelled) to this URL.                          │
# └──────────────────────────────────────────────────────────────┘

# Platform markup on delivery fee (% on top of 3PL cost, 0 = pass-through)
DELIVERY_PLATFORM_MARKUP_PCT=0

# Dunzo API (future)
# DUNZO_API_KEY=
# DUNZO_BASE_URL=https://apis.staging.dunzo.in

# Shadowfax API (future)
# SHADOWFAX_API_KEY=
# SHADOWFAX_BASE_URL=

# ── WHATSAPP CATALOG WEBHOOK ──────────────────────────────────
# ┌──────────────────────────────────────────────────────────────┐
# │  CATALOG WEBHOOK                                             │
# │                                                              │
# │  This is automatically handled by the main WhatsApp webhook. │
# │  No separate URL needed — catalog events arrive at:          │
# │  {BASE_URL}/webhooks/catalog                                 │
# │                                                              │
# │  Ensure "catalog" is subscribed in WhatsApp webhook fields.  │
# └──────────────────────────────────────────────────────────────┘

# ── WHATSAPP DIRECTORY (separate WABA for discovery) ───────────
# A second WhatsApp Business number used for restaurant discovery.
# Customers message this number to search/browse restaurants.
#
# ┌──────────────────────────────────────────────────────────────┐
# │  DIRECTORY WABA WEBHOOK                                      │
# │                                                              │
# │  In Meta Developer Console (for your DIRECTORY app/WABA):    │
# │  Meta App → WhatsApp → Configuration → Webhook               │
# │                                                              │
# │  Callback URL:    {BASE_URL}/webhooks/directory              │
# │  Verify Token:    (paste the value you set below)            │
# │                                                              │
# │  Subscribed Fields:                                          │
# │    ✅ messages                                                │
# └──────────────────────────────────────────────────────────────┘
DIRECTORY_WA_PHONE_NUMBER_ID=
DIRECTORY_WA_ACCESS_TOKEN=
DIRECTORY_WA_VERIFY_TOKEN=your-directory-verify-token

# ── WHATSAPP CHECKOUT (encrypted order flow) ───────────────────
# WhatsApp Checkout sends encrypted order data using RSA+AES-GCM.
#
# ┌──────────────────────────────────────────────────────────────┐
# │  CHECKOUT WEBHOOK                                            │
# │                                                              │
# │  In Meta Developer Console:                                  │
# │  Meta App → WhatsApp → Configuration → Checkout Settings     │
# │                                                              │
# │  Callback URL:    {BASE_URL}/webhooks/checkout               │
# │  Verify Token:    (paste the value you set below)            │
# │                                                              │
# │  Public Key:      Upload the RSA public key generated via    │
# │                   POST /api/admin/checkout/generate-keys     │
# │                                                              │
# │  Webhook Secret:  Set a secret below, enter the same in Meta │
# └──────────────────────────────────────────────────────────────┘
#
# Generate RSA keys: POST /api/admin/checkout/generate-keys
# Then set privateKeyB64 here and upload publicKey to Meta
WA_CHECKOUT_PRIVATE_KEY_B64=
WA_CHECKOUT_VERIFY_TOKEN=your-checkout-verify-token
WA_CHECKOUT_WEBHOOK_SECRET=your-checkout-webhook-secret


# ── REFERRAL PROGRAM (Directory) ──────────────────────────────
# Commission percentage on referral orders (default: 7.5%)
REFERRAL_COMMISSION_PCT=7.5
# Hours window during which referral link is valid (default: 8)
REFERRAL_WINDOW_HRS=8

# ── WHATSAPP FLOWS (Optional) ────────────────────────────────
# ID of the customer rating/feedback flow (leave empty to disable)
# RATING_FLOW_ID=

# ── CRON (Vercel Cron or external cron service) ──────────────
# Secret to authenticate cron requests (set in Vercel dashboard as CRON_SECRET)
CRON_SECRET=your-cron-secret

# Secret for the webhook health diagnostic endpoint
# Access: GET /api/webhook-health?key=YOUR_KEY
WEBHOOK_HEALTH_KEY=your-webhook-health-key

# ── FEATURE FLAGS ─────────────────────────────────────────────
# POS integrations (PetPooja, UrbanPiper, DotPe) — hard-disabled at the code level.
# Both flags below must be `true` to re-enable, AND the POS_DISABLED guards in
# backend/src/services/integrations/*, services/posSync.js, jobs/pos-sync.js,
# webhooks/pos.js, and routes/integrations.js must be removed.
# POS_DISABLED — not in use
POS_ENABLED=false
# POS_DISABLED — not in use
ENABLE_POS_INTEGRATIONS=false

# ── WEBSOCKET (real-time push via AWS API Gateway + Lambda) ──────
# Auto-enables when BROADCAST_LAMBDA_URL is set. Without it, dashboards fall back to polling.
# BROADCAST_LAMBDA_URL — Function URL of the wsBroadcast Lambda
# BROADCAST_API_KEY — shared secret between Vercel backend and Lambda
# WEBSOCKET_URL — wss:// URL of the API Gateway WebSocket API (set in frontend via window.WEBSOCKET_URL)
# BROADCAST_LAMBDA_URL=https://xxxxx.lambda-url.ap-south-1.on.aws/
# BROADCAST_API_KEY=your-broadcast-secret
# WEBSOCKET_URL=wss://xxxxx.execute-api.ap-south-1.amazonaws.com/production

# ── AWS S3 + CloudFront (disabled — add credentials to enable image pipeline) ──
# Product images stored in S3, served via CloudFront CDN.
# Used for: menu item images (presigned upload from dashboard), logos, branch photos.
# Auto-enables when all 4 vars are set.
#
# AWS IAM User needs: s3:PutObject, s3:GetObject, s3:DeleteObject, s3:ListBucket
# on the bucket. Presigned URLs expire after 5 minutes.
#
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=gullybite-images
# CLOUDFRONT_URL — full CloudFront distribution URL, no trailing slash
# AWS_CLOUDFRONT_DOMAIN=d1234567890.cloudfront.net

# Default food image URL — used when menu items have no image
# Upload a generic food placeholder to S3/CloudFront or use any public URL
# DEFAULT_FOOD_IMAGE_URL=https://your-cdn.com/default-food.png

# ── POS INTEGRATIONS (hard-disabled — see POS_ENABLED above) ──
# Per-restaurant credentials are entered in the dashboard.
# Platform-level keys only needed for PetPooja:
# POS_DISABLED — not in use
# PETPOOJA_APP_KEY=
# POS_DISABLED — not in use
# PETPOOJA_API_KEY=
# Webhook HMAC secret for signature verification (optional — if unset, signatures
# are logged-only and not enforced. See backend/src/webhooks/pos.js).
# POS_DISABLED — not in use
# PETPOOJA_WEBHOOK_SECRET=

# ================================================================
# QUICK REFERENCE — ALL URLs TO SET IN EXTERNAL DASHBOARDS
# ================================================================
#
# Replace {BASE_URL} with your actual domain (e.g. https://api.gullybite.com)
#
# ┌─────────────────────┬────────────────────────────────────────┐
# │ WHERE TO SET        │ URL                                    │
# ├─────────────────────┼────────────────────────────────────────┤
# │ Meta OAuth Redirect │ {BASE_URL}/auth/callback               │
# │                     │ (Facebook Login → Valid OAuth URIs)     │
# ├─────────────────────┼────────────────────────────────────────┤
# │ WhatsApp Webhook    │ {BASE_URL}/webhooks/whatsapp           │
# │                     │ (Meta App → WhatsApp → Configuration)  │
# ├─────────────────────┼────────────────────────────────────────┤
# │ Razorpay Webhook    │ {BASE_URL}/webhooks/razorpay           │
# │                     │ (Razorpay → Settings → Webhooks)       │
# ├─────────────────────┼────────────────────────────────────────┤
# │ Porter/3PL Webhook  │ {BASE_URL}/webhooks/delivery           │
# │                     │ (Porter Dashboard → Settings)           │
# ├─────────────────────┼────────────────────────────────────────┤
# │ Directory Webhook   │ {BASE_URL}/webhooks/directory          │
# │                     │ (Meta App #2 → WhatsApp → Config)      │
# ├─────────────────────┼────────────────────────────────────────┤
# │ Checkout Webhook    │ {BASE_URL}/webhooks/checkout           │
# │                     │ (Meta App → WhatsApp → Checkout)        │
# ├─────────────────────┼────────────────────────────────────────┤
# │ Catalog Feed URL    │ {BASE_URL}/feed/{feedToken}            │
# │                     │ (Meta Commerce Manager → Data Sources)  │
# ├─────────────────────┼────────────────────────────────────────┤
# │ Payment Success     │ {BASE_URL}/payment-success             │
# │                     │ (Razorpay Payment Link → Callback URL)  │
# └─────────────────────┴────────────────────────────────────────┘
