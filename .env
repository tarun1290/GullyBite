# ================================================================
# GullyBite — Environment Variables
# HOW TO USE: Copy this file → rename to .env → fill all values
# Command:  cp .env.example .env
# ================================================================

# ── SERVER ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Your public URL. During development use your ngrok URL.
# Get ngrok: https://ngrok.com (free) → run: ngrok http 3000
# Production: use your real domain like https://api.gullybite.com
BASE_URL=https://gully-bite.vercel.app

# Secret for signing login tokens. Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# ── DATABASE ────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local:   postgresql://postgres:yourpassword@localhost:5432/gullybite
# Neon:    postgresql://neondb_owner:xxxx@ep-xxx.us-east-1.aws.neon.tech/neondb
# Supabase: postgresql://postgres:xxxx@db.xxx.supabase.co:5432/postgres
host=db.yamqwwxjlzgvipwyozlo.supabase.co
Port=5432
Database=postgres
User=postgres
DATABASE_URL=postgresql://postgres:6h8MwgU8qcvkvVx6@db.yamqwwxjlzgvipwyozlo.supabase.co:5432/postgres

# ── META / FACEBOOK ─────────────────────────────────────────────
# Where to find these:
# developers.facebook.com → Your App → Settings → Basic
META_APP_ID=831623239943250
META_APP_SECRET=b5b4ca23c2f443b3f92c4a5c2159b62d

# Where Meta redirects users after they approve your app via OAuth
# MUST exactly match what you set in:
# Meta App → Settings → Advanced → Valid OAuth Redirect URIs
META_OAUTH_REDIRECT_URI=https://gully-bite.vercel.app/auth/callback

# ── WHATSAPP ────────────────────────────────────────────────────
# API version - keep as v25.0 (current stable)
WA_API_VERSION=v25.0

# A string YOU choose. Used to verify Meta's webhook setup call.
# Any random text works: "GullyBite-secret-2024" etc.
# Must match exactly what you enter in Meta Developer Console webhook settings
WEBHOOK_VERIFY_TOKEN=GullyBite@2026

# Same as META_APP_SECRET - used to verify webhook request signatures
WEBHOOK_APP_SECRET=b5b4ca23c2f443b3f92c4a5c2159b62d

# ── RAZORPAY ────────────────────────────────────────────────────
# Get these from: razorpay.com → Settings → API Keys
# Use rzp_test_ keys for testing, rzp_live_ for production
RAZORPAY_KEY_ID=rzp_test_SNcswAPinuC47c
RAZORPAY_KEY_SECRET=RwQ1Ad0u02g4GlHNFhdrBfCk

# Get from: razorpay.com → Settings → Webhooks → your webhook → secret
RAZORPAY_WEBHOOK_SECRET=GullyBite@2026

# How long before WhatsApp Pay / payment links expire (minutes)
PAYMENT_LINK_EXPIRY_MINS=15

# ── WHATSAPP PAY (Razorpay) ──────────────────────────────────────
# Configuration name from Meta Business Manager:
#   WhatsApp Manager → Payment Settings → Add payment configuration → Name
# Must match exactly — links Meta's native payment UI to your Razorpay account
RAZORPAY_WA_CONFIG_NAME=GullyBite

# Razorpay X virtual account number for outgoing payouts to restaurants
# Found at: razorpay.com → Razorpay X → Account Settings → Account Number
RAZORPAY_ACCOUNT_NUMBER=

# ── PLATFORM FEES ───────────────────────────────────────────────
# Your commission percentage from restaurant earnings
PLATFORM_FEE_PERCENT=0

# Default delivery fee charged to customers (in rupees)
DEFAULT_DELIVERY_FEE=40
